<Window x:Class="RegionBlocker.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roblox Preview — Detect Points"
        Height="560" Width="760"
        MinHeight="420" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="#0A0A0F"
        Foreground="White"
        FontFamily="Consolas"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.50"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeutralBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"  Value="#1A1A2E"/>
            <Setter Property="BorderBrush" Value="#3A3A5C"/>
            <Setter Property="Foreground"  Value="#C0C0E0"/>
            <Setter Property="Padding"     Value="10 0"/>
        </Style>
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"  Value="#0D2E0D"/>
            <Setter Property="BorderBrush" Value="#2A6A2A"/>
            <Setter Property="Foreground"  Value="#66FF66"/>
            <Setter Property="Padding"     Value="10 0"/>
        </Style>
        <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"  Value="#2E0D0D"/>
            <Setter Property="BorderBrush" Value="#6A2A2A"/>
            <Setter Property="Foreground"  Value="#FF6666"/>
            <Setter Property="Padding"     Value="10 0"/>
        </Style>
        <Style x:Key="OrangeBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"  Value="#2E1A00"/>
            <Setter Property="BorderBrush" Value="#7A4A00"/>
            <Setter Property="Foreground"  Value="#FFAA33"/>
            <Setter Property="Padding"     Value="10 0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0 0 0 8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="PREVIEW" FontSize="13" FontWeight="Bold" Foreground="#AAAAFF" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtStatus" Text="  —  Roblox not open" FontSize="11"
                           Foreground="#666688" VerticalAlignment="Center" Margin="8 0 0 0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Refresh:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0 0 6 0"/>
                <ComboBox x:Name="cboRefresh" Width="70" Height="22" FontSize="11" FontFamily="Consolas"
                          Background="#1A1A2E" Foreground="#C0C0E0" BorderBrush="#3A3A5C"
                          SelectionChanged="CboRefresh_SelectionChanged">
                    <ComboBoxItem Content="500 ms"  Tag="500"/>
                    <ComboBoxItem Content="1000 ms" Tag="1000" IsSelected="True"/>
                    <ComboBoxItem Content="2000 ms" Tag="2000"/>
                    <ComboBoxItem Content="Pause"   Tag="0"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- CANVAS PREVIEW -->
        <Border Grid.Row="1" BorderBrush="#252540" BorderThickness="1"
                Background="#050508" CornerRadius="4" Margin="0 0 0 8">
            <Grid>
                <Canvas x:Name="previewCanvas" ClipToBounds="True"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        MouseMove="Canvas_MouseMove"
                        Cursor="Arrow">
                    <Image x:Name="imgPreview" Stretch="Uniform"
                           Canvas.Left="0" Canvas.Top="0"/>
                </Canvas>
                <TextBlock x:Name="txtOverlay"
                           Text="Roblox is not running&#x0a;Open Roblox to see preview"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" Foreground="#444466"
                           FontSize="14" LineHeight="22"/>
            </Grid>
        </Border>

        <!-- POINT LIST -->
        <Grid Grid.Row="2" Margin="0 0 0 8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#252540" BorderThickness="1" CornerRadius="3" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0 0 0 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"      Foreground="#666688" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="Rel X %" Foreground="#666688" FontSize="10"/>
                        <TextBlock Grid.Column="2" Text="Rel Y %" Foreground="#666688" FontSize="10"/>
                        <TextBlock Grid.Column="3" Text="Color"  Foreground="#666688" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Black?" Foreground="#666688" FontSize="10" HorizontalAlignment="Center"/>
                    </Grid>

                    <Separator Grid.Row="1" Background="#252540" Margin="0 0 0 4"/>

                    <ItemsControl x:Name="pointsList" Grid.Row="2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="26" Margin="0 1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               Foreground="#AAAAFF" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding RelXPct, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                             Background="#0C0C18" Foreground="#D0D0FF"
                                             BorderBrush="#252550" FontSize="11" Padding="3 2"
                                             Margin="2 0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2"
                                             Text="{Binding RelYPct, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                             Background="#0C0C18" Foreground="#D0D0FF"
                                             BorderBrush="#252550" FontSize="11" Padding="3 2"
                                             Margin="2 0" VerticalAlignment="Center"/>
                                    <Border Grid.Column="3"
                                            Width="32" Height="16" CornerRadius="2"
                                            Background="{Binding SwatchBrush}"
                                            BorderBrush="#333" BorderThickness="1"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding IsBlackText}"
                                               Foreground="{Binding IsBlackFore}"
                                               FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Right controls -->
            <StackPanel Grid.Column="1" Margin="8 0 0 0" VerticalAlignment="Top">
                <TextBlock Text="CONTROLS" Foreground="#666688" FontSize="10" Margin="0 0 0 6"/>
                <Button x:Name="btnAddPoint" Content="+ Add point" Style="{StaticResource GreenBtn}"
                        Height="26" Margin="0 0 0 4" Click="BtnAddPoint_Click"/>
                <Button x:Name="btnRemoveLast" Content="- Remove last" Style="{StaticResource RedBtn}"
                        Height="26" Margin="0 0 0 4" Click="BtnRemoveLast_Click"/>
                <Button x:Name="btnReset" Content="Reset defaults" Style="{StaticResource OrangeBtn}"
                        Height="26" Margin="0 0 0 12" Click="BtnReset_Click"/>

                <TextBlock Text="CLICK on image to" Foreground="#555577" FontSize="10" TextWrapping="Wrap"/>
                <TextBlock Text="place a new point" Foreground="#555577" FontSize="10"/>
                <TextBlock Text="DRAG a point to" Foreground="#555577" FontSize="10" Margin="0 6 0 0" TextWrapping="Wrap"/>
                <TextBlock Text="move it" Foreground="#555577" FontSize="10"/>

                <Separator Background="#252540" Margin="0 10"/>
                <TextBlock Text="Black if &gt;=" Foreground="#888" FontSize="10" Margin="0 0 0 4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="sliderThreshold" Minimum="1" Maximum="5" Value="4"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            Foreground="#AAAAFF" Margin="0 4 4 0"
                            ValueChanged="SliderThreshold_ValueChanged"/>
                    <TextBlock x:Name="txtThreshold" Grid.Column="1" Text="4" Width="16"
                               Foreground="#AAAAFF" FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- BOTTOM BUTTONS -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtHint" Text="Drag points on the preview to reposition them"
                       Foreground="#555577" FontSize="10" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Apply" Style="{StaticResource GreenBtn}"
                        Height="28" Width="90" Margin="0 0 8 0" Click="BtnApply_Click"/>
                <Button Content="Close" Style="{StaticResource NeutralBtn}"
                        Height="28" Width="70" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
